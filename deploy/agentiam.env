# Agent-IAM server configuration (systemd EnvironmentFile).
# Copy to /etc/agentiam/agentiam.env and edit. Keep it mode 0640, owned by
# root:agentiam — it holds the database DSN.

# --- core ---
# Public URL of this server. Becomes the token `iss` claim and must match
# AGENTMESH_OAUTH_ISSUER on every node that trusts this server. Required.
AGENTIAM_ISSUER=https://iam.example.com

# Listen address (default :8090). Terminate TLS at a reverse proxy in front
# of it — never serve tokens over plaintext on an untrusted network.
AGENTIAM_HTTP_ADDR=127.0.0.1:8090

# Path to the RSA private-key PEM used to sign access tokens (RS256).
# Generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
# If unset, an EPHEMERAL key is generated — demo only, tokens stop validating
# on restart.
AGENTIAM_SIGNING_KEY=/etc/agentiam/signing-key.pem

# Default access-token lifetime (default 15m). Keep it short: agents re-fetch
# via client_credentials, so there is nothing long-lived to leak.
AGENTIAM_TOKEN_TTL=15m

# Postgres client registry. If unset, an in-memory store is used — demo only,
# client registrations vanish on restart.
AGENTIAM_DATABASE_URL=postgres://agentiam:CHANGEME@localhost:5432/agentiam?sslmode=require
