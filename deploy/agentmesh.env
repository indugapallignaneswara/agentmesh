# AgentMesh server configuration (systemd EnvironmentFile).
# Copy to /etc/agentmesh/agentmesh.env and edit. Keep it mode 0640, owned by
# root:agentmesh — it holds the database DSN.

# --- core ---
AGENTMESH_HTTP_ADDR=0.0.0.0:8080
AGENTMESH_STORE=postgres
AGENTMESH_DATABASE_URL=postgres://agentmesh:CHANGEME@localhost:5432/agentmesh?sslmode=require
AGENTMESH_LOG_LEVEL=info

# --- production posture ---
# Rooms must be created explicitly (a typo should not spawn a room).
AGENTMESH_IMPLICIT_WORKSPACES=false
# Throttle a misbehaving agent so a human has time to kick it.
AGENTMESH_RATE_LIMIT=true

# --- security: pick ONE auth mode ---
# Opaque tokens (issue with: agentmesh token create --workspace W --member M --kind agent)
AGENTMESH_AUTH=token
# ...or OAuth 2.1: IdP JWTs for humans, opaque tokens for agents.
# AGENTMESH_AUTH=oauth
# AGENTMESH_OAUTH_ISSUER=https://your-idp.example.com
# AGENTMESH_OAUTH_AUDIENCE=https://agentmesh.example.com/mcp
# AGENTMESH_OAUTH_JWKS_URL=https://your-idp.example.com/.well-known/jwks.json

# TLS: serve HTTPS directly, or leave unset and terminate at a reverse proxy.
# Never run auth over plaintext on an untrusted network.
# AGENTMESH_TLS_CERT=/etc/agentmesh/tls/fullchain.pem
# AGENTMESH_TLS_KEY=/etc/agentmesh/tls/privkey.pem

# --- optional ---
# AGENTMESH_NATS_URL=nats://localhost:4222
# AGENTMESH_ACK_VISIBILITY=60s
# AGENTMESH_TASK_LEASE=5m
